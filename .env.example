# Default environment variables for local development.
# This file serves as a template. A functional .env file will be generated
# for local development when you run 'scripts/bootstrap_local.sh'.

# --- Database Configuration ---
# The bootstrap script will configure your .env for local PostgreSQL by default.
# If you wish to use SQLite instead, comment out the DATABASE_URL line in your
# generated .env file and uncomment the one below.
# DATABASE_URL=sqlite:///./xservice-dev.db

# --- Docker Compose PostgreSQL Initialization ---
# The bootstrap script will generate strong, random credentials for these.
# Do NOT commit the generated .env file.
# These variables are required by docker-compose.yml on startup.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=xservice